{
  "name": "n8n-mcp",
  "version": "1.0.0",
  "description": "MCP server for Florida permit orchestration workflows",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "bridge:dev": "bun --hot src/http-bridge.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "bridge:start": "bun src/http-bridge.ts",
    "test": "bun run typecheck",
    "discover:endpoints": "tsx scripts/discover-endpoints.ts",
    "discover:network": "tsx scripts/capture-network.ts",
    "discover:portals:all": "tsx scripts/discover-county-portals.ts",
    "discover:network:all": "tsx scripts/capture-network-all-counties.ts",
    "catalog:build": "tsx scripts/build-county-api-catalog.ts",
    "catalog:map-tools": "tsx scripts/build-mcp-tool-mapping.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "@types/bun": "latest"
  },
  "private": true
}
